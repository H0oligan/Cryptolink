package subscriptionapi

import (
	"net/http"
	"time"

	"github.com/google/uuid"
	"github.com/labstack/echo/v4"
	"github.com/cryptolink/cryptolink/internal/server/http/common"
	"github.com/cryptolink/cryptolink/internal/service/payment"
	"github.com/cryptolink/cryptolink/internal/webhook"
	"github.com/pkg/errors"

	"github.com/cryptolink/cryptolink/pkg/api-dashboard/v1/model"
)

type AdminPaymentResponse struct {
	ID              int64   `json:"id"`
	PublicID        string  `json:"public_id"`
	MerchantID      int64   `json:"merchant_id"`
	Status          string  `json:"status"`
	WebhookSentAt   *string `json:"webhook_sent_at"`
	WebhookAttempts int     `json:"webhook_attempts"`
	CreatedAt       string  `json:"created_at"`
	UpdatedAt       string  `json:"updated_at"`
}

// AdminListPayments returns payments needing webhook attention (admin only)
// GET /api/dashboard/v1/admin/payments?public_id=...
func (h *Handler) AdminListPayments(c echo.Context) error {
	ctx := c.Request().Context()

	publicIDStr := c.QueryParam("public_id")
	if publicIDStr == "" {
		// Return payments needing retry
		payments, err := h.paymentService.GetPaymentsNeedingWebhookRetry(ctx, 4)
		if err != nil {
			h.logger.Error().Err(err).Msg("failed to list payments needing webhook retry")
			return c.JSON(http.StatusInternalServerError, &model.ErrorResponse{
				Message: "unable to list payments",
				Status:  "internal_error",
			})
		}

		response := make([]*AdminPaymentResponse, len(payments))
		for i, p := range payments {
			response[i] = paymentToAdminResponse(p)
		}

		return c.JSON(http.StatusOK, map[string]interface{}{"results": response})
	}

	publicID, err := uuid.Parse(publicIDStr)
	if err != nil {
		return common.ValidationErrorResponse(c, "invalid public_id format")
	}

	p, err := h.paymentService.GetByPublicID(ctx, publicID)
	if err != nil {
		if errors.Is(err, payment.ErrNotFound) {
			return common.NotFoundResponse(c, "payment not found")
		}
		return c.JSON(http.StatusInternalServerError, &model.ErrorResponse{
			Message: "unable to get payment",
			Status:  "internal_error",
		})
	}

	return c.JSON(http.StatusOK, paymentToAdminResponse(p))
}

// AdminResendWebhook force-resends webhook for a payment (admin only)
// POST /api/dashboard/v1/admin/payments/:paymentId/resend-webhook
func (h *Handler) AdminResendWebhook(c echo.Context) error {
	ctx := c.Request().Context()

	publicIDStr := c.Param("paymentId")
	publicID, err := uuid.Parse(publicIDStr)
	if err != nil {
		return common.ValidationErrorResponse(c, "invalid payment ID format")
	}

	p, err := h.paymentService.GetByPublicID(ctx, publicID)
	if err != nil {
		if errors.Is(err, payment.ErrNotFound) {
			return common.NotFoundResponse(c, "payment not found")
		}
		return c.JSON(http.StatusInternalServerError, &model.ErrorResponse{
			Message: "unable to get payment",
			Status:  "internal_error",
		})
	}

	mt, err := h.merchantService.GetByID(ctx, p.MerchantID, false)
	if err != nil {
		return c.JSON(http.StatusInternalServerError, &model.ErrorResponse{
			Message: "unable to get merchant",
			Status:  "internal_error",
		})
	}

	// Re-verify payment still belongs to this merchant (TOCTOU guard)
	if _, err := h.paymentService.GetByID(ctx, p.MerchantID, p.ID); err != nil {
		return common.NotFoundResponse(c, "payment not found or inaccessible")
	}

	webhookURL := mt.Settings().WebhookURL()
	if webhookURL == "" {
		return c.JSON(http.StatusBadRequest, &model.ErrorResponse{
			Message: "merchant has no webhook URL configured",
			Status:  "validation_error",
		})
	}

	type PaymentWebhook struct {
		ID     string `json:"id"`
		Status string `json:"status"`
		IsTest bool   `json:"isTest"`
	}

	wh := PaymentWebhook{
		ID:     p.MerchantOrderUUID.String(),
		Status: p.Status.String(),
		IsTest: p.IsTest,
	}

	if err := webhook.Send(ctx, webhookURL, mt.Settings().WebhookSignatureSecret(), wh); err != nil {
		h.logger.Warn().Err(err).
			Int64("payment_id", p.ID).
			Str("webhook_url", webhookURL).
			Msg("admin resend webhook failed")

		return c.JSON(http.StatusOK, map[string]interface{}{
			"success": false,
			"message": "webhook delivery failed: " + err.Error(),
		})
	}

	if err := h.paymentService.SetWebhookTimestamp(ctx, p.MerchantID, p.ID, time.Now()); err != nil {
		h.logger.Error().Err(err).Int64("payment_id", p.ID).Msg("failed to set webhook timestamp")
	}

	if err := h.paymentService.ResetWebhookAttempts(ctx, p.MerchantID, p.ID); err != nil {
		h.logger.Error().Err(err).Int64("payment_id", p.ID).Msg("failed to reset webhook attempts")
	}

	h.logger.Info().Int64("payment_id", p.ID).Msg("admin resent webhook successfully")

	return c.JSON(http.StatusOK, map[string]interface{}{
		"success": true,
		"message": "webhook delivered successfully",
	})
}

func paymentToAdminResponse(p *payment.Payment) *AdminPaymentResponse {
	r := &AdminPaymentResponse{
		ID:              p.ID,
		PublicID:        p.PublicID.String(),
		MerchantID:      p.MerchantID,
		Status:          p.Status.String(),
		WebhookAttempts: p.WebhookAttempts,
		CreatedAt:       p.CreatedAt.Format(time.RFC3339),
		UpdatedAt:       p.UpdatedAt.Format(time.RFC3339),
	}

	if p.WebhookSentAt != nil {
		s := p.WebhookSentAt.Format(time.RFC3339)
		r.WebhookSentAt = &s
	}

	return r
}
